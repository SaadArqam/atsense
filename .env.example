# ── Groq LLM ──────────────────────────────────────────────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Groq model selection (see https://console.groq.com/docs/models) ────────
# Recommended: llama-3.3-70b-versatile (fast + high quality)
# Alternatives: llama-3.1-8b-instant (faster, smaller), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Groq generation settings ───────────────────────────────────────────────
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.3

# ── FastAPI server ─────────────────────────────────────────────────────────
# Used by the Streamlit frontend to call the backend
BACKEND_URL=http://localhost:8000
